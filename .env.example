# Copy this file to .env and set your values before running docker compose up.
# .env is gitignored — never commit it.

# ── Splunk credentials ─────────────────────────────────────────────────────
# Password for the Splunk admin account.
# Must be at least 8 characters and contain letters + numbers.
SPLUNK_PASSWORD=Chang3d!

# ── HTTP Event Collector ───────────────────────────────────────────────────
# Pre-set HEC token so you can send events without navigating the Splunk UI.
# Use any UUID-format string, or generate one: uuidgen
SPLUNK_HEC_TOKEN=a8b4c2d6-e0f1-4321-9876-abcdef012345

# ── Web ports ─────────────────────────────────────────────────────────
# Host port for the lab guide (includes Ask Splunk at /ask/ on the same port).
LAB_GUIDE_PORT=3131

# ── Ask Splunk Chat (optional) ────────────────────────────────────────
# Anthropic API key for the Ask Splunk chat interface.
# Without this, the chat container starts but shows a setup prompt.
# All other lab features work without it.
# ANTHROPIC_API_KEY=sk-ant-...

# ── splunk-dashboard-gen skill ───────────────────────────────────────
# The splunk-dashboard-gen Claude Code skill calls the Splunk REST API
# directly (not via Docker) and reads credentials from $HOME/.claude/env.sh.
# Docker's .env is NOT read by skills at runtime.
#
# Setup: copy env.sh.example → $HOME/.claude/env.sh, then set:
#   SPLUNK_HOST=localhost
#   SPLUNK_USER=admin
#   SPLUNK_PASS=<your SPLUNK_PASSWORD value above>
#
# The skill also requires the HuggingFace MCP to be connected in Claude Code
# for AI-generated dashboard background images.

# ── MCP / Splunk search tuning ────────────────────────────────────────
# Axios timeout (ms) for Splunk REST API calls from the MCP server.
# search_oneshot is synchronous — Splunk holds the connection open until done.
# Increase for wide time-range queries on slower hardware.
# SPLUNK_TIMEOUT_MS=120000

# Maximum events returned per MCP search call.
# The upstream default is 100 000 — lower values give faster interactive responses.
# SPL_MAX_EVENTS_COUNT=1000
