# Proxmox configuration
PROXMOX_HOST=192.168.1.10
PROXMOX_API_PORT=8006
PROXMOX_NODE=pve
# Create an API token in Proxmox: Datacenter > Permissions > API Tokens
# Token ID format: user@realm!tokenname  (e.g. root@pam!splunk-lab)
PROXMOX_API_TOKEN_ID=root@pam!splunk-lab
PROXMOX_API_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# Set to true if Proxmox has a valid TLS certificate; false for self-signed (homelab default)
PROXMOX_TLS_VERIFY=false

# LXC container configuration
LXC_ID=200
LXC_HOSTNAME=splunk-lab
LXC_PASSWORD=changeme
LXC_CORES=4
LXC_MEMORY=8192
LXC_SWAP=2048
LXC_DISK=50
LXC_STORAGE=local-lvm
LXC_BRIDGE=vmbr0
LXC_IP=192.168.1.200/24
LXC_GATEWAY=192.168.1.1
LXC_DNS=8.8.8.8
LXC_TEMPLATE=local:vztmpl/ubuntu-24.04-standard_24.04-2_amd64.tar.zst
# Path to your local SSH public key — written to /root/.ssh/authorized_keys in the LXC at creation time
LXC_SSH_PUBKEY=~/.ssh/id_rsa.pub

# Splunk Docker configuration
SPLUNK_IMAGE=splunk/splunk:latest
SPLUNK_ADMIN_USER=admin
SPLUNK_ADMIN_PASSWORD=changeme123!
SPLUNK_HTTP_PORT=8000
SPLUNK_MGMT_PORT=8089
SPLUNK_HEC_PORT=8088
SPLUNK_INDEX_PORT=9997
SPLUNK_ROLE=splunk_standalone
# Memory limits for the Splunk container (Docker deploy resource syntax)
SPLUNK_MEMORY_LIMIT=8G
SPLUNK_MEMORY_RESERVATION=4G
# Directory on the LXC where docker-compose.yml and its .env are placed
SPLUNK_COMPOSE_DIR=/opt/splunk-docker

# Splunk license
# Use 'Free' for the trial/free tier, or a URI/path to a .lic file for Enterprise
SPLUNK_LICENSE_URI=Free
# Local path to a .lic file — if set, the file is pushed to the container at configure time
SPLUNK_LICENSE_FILE=

# HEC token — leave blank to have configure-splunk.sh create one automatically
SPLUNK_HEC_TOKEN=
