# Claude Code skill credentials — copy to $HOME/.claude/env.sh
#
# This file is sourced at runtime by Claude Code skills that need to
# call the Splunk REST API directly (e.g. splunk-dashboard-gen).
# It is separate from .env (which is read by Docker Compose only).
#
# Setup:
#   cp env.sh.example $HOME/.claude/env.sh
#   chmod 600 $HOME/.claude/env.sh   # keep credentials private
#   # then edit the values below

# ── Splunk REST API ────────────────────────────────────────────────────────
# Host where Splunk is running. For the local lab this is always localhost.
export SPLUNK_HOST=localhost

# Basic auth credentials (matches SPLUNK_PASSWORD in your .env file).
export SPLUNK_USER=admin
export SPLUNK_PASS=Chang3d!     # replace with your actual SPLUNK_PASSWORD

# Token auth (optional — use instead of SPLUNK_USER / SPLUNK_PASS).
# Generate in Splunk Web: Settings → Tokens → New Token
# Uncomment and set if you prefer token-based auth.
# export SPLUNK_API_TOKEN=
